{
  "name": "froggy-microblog",
  "version": "1.0.0",
  "description": "A frog desktop pet that prompts you hourly to micro-blog what you've been doing, saved to your team vault.",
  "main": "src/main.js",
  "author": "ruben.gres",
  "license": "MIT",
  "scripts": {
    "start": "electron .",
    "studio": "node tools/serve.js",
    "test:a": "electron . --user-data-dir=/tmp/froggy-a",
    "test:b": "electron . --user-data-dir=/tmp/froggy-b"
  },
  "devDependencies": {
    "electron": "^33.0.0"
  },
  "dependencies": {
    "@supabase/supabase-js": "^2.110.0",
    "ws": "^8.21.0"
  },
  "optionalDependencies": {
    "uiohook-napi": "^1.5.4"
  }
}
